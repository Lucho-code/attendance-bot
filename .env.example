# Token del bot de Telegram (obtenido desde @BotFather)
TELEGRAM_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# Nombre de la empresa (aparece en el mensaje de bienvenida del bot)
COMPANY_NAME=Mi Empresa SRL

# IDs de Telegram de los administradores, separados por coma
# Para saber tu ID: enviá un mensaje a @userinfobot en Telegram
ADMIN_IDS=123456789,987654321

# Ruta del archivo de base de datos
DB_PATH=C:\Users\Lucio\attendance-bot\attendance.db

# Email (opcional) — usar Gmail con contraseña de aplicación
# EMAIL_TO acepta múltiples destinos separados por coma
EMAIL_FROM=tucuenta@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_TO=tucuenta@gmail.com,otroemail@gmail.com

# Tolerancia de entrada/salida en minutos (default: 15)
# Si alguien entra a las 07:08 con GRACE_MINUTES=15 → se cuenta como 07:00
# Si alguien sale a las 15:53 → se cuenta como 16:00
GRACE_MINUTES=15

# Verificación por geolocalización (opcional)
# Si REQUIRE_LOCATION=true, los empleados deben compartir su ubicación para fichar
# Coordenadas de la oficina: buscá tu dirección en Google Maps y copiá lat,lon
REQUIRE_LOCATION=false
OFFICE_LAT=-32.9468
OFFICE_LON=-60.6393
OFFICE_RADIUS_METERS=300
